# ClickHouse Cloud connection credentials
# Copy this file to .env and fill in your values.
#
# To get a free ClickHouse Cloud trial:
#   1. Visit https://clickhouse.cloud
#   2. Sign up for a free trial
#   3. Create a service (choose your region)
#   4. Copy the connection details below

CLICKHOUSE_HOST=your-instance.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password-here
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=true
